# AEOS Production Environment Variables
# Copy to .env.production and fill in values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://aeos:CHANGE_ME@postgres:5432/aeos
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Security ──
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ENVIRONMENT=production

# ── AI ──
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── CORS ──
CORS_ORIGINS=https://your-domain.com

# ── Frontend (Vercel) ──
NEXT_PUBLIC_API_URL=https://your-backend-domain.com
